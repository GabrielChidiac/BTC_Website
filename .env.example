# AI APIs
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
KIE_API_KEY=                                        # Fallback only
OPENAI_API_KEY=                                     # TTS for the Pro audio brief (Pillar 2, gpt-4o-mini-tts)

# Data APIs
COINGECKO_API_KEY=                                   # Free Demo key (no CC required)
SEARCHAPI_KEY=                                       # SearchAPI.io Google News scraping
JINA_API_KEY=                                        # Jina Reader (free key, 200 RPM vs 20)

# Infrastructure
TRIGGER_SECRET_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                           # Server-side writes
REVALIDATION_SECRET=                                 # Protects /api/revalidate
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (subscription payments)
STRIPE_SECRET_KEY=                                   # Stripe secret key (sk_live_... or sk_test_...)
STRIPE_WEBHOOK_SECRET=                               # Webhook endpoint signing secret (whsec_...)
NEXT_PUBLIC_STRIPE_MONTHLY_URL=                      # Stripe Payment Link for $7/month plan
NEXT_PUBLIC_STRIPE_ANNUAL_URL=                       # Stripe Payment Link for $59/year plan

# AI Brain
EXPERT_CONTEXT_ENABLED=                              # "false" disables the expert analytical framework injection into AI Brain + Looking Ahead (default: enabled)

# Lightning tips (CoinOS)
COINOS_API_TOKEN=                                    # JWT from coinos.io localStorage `token`. Rotate by re-logging into coinos.io.

# On-chain BTC tip (mainnet, public address; rotate by updating this and redeploying)
NEXT_PUBLIC_BTC_TIP_ADDRESS=                         # bc1q... receive address from BitBox02. Mainnet only.
